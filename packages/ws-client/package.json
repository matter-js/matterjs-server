            }
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "clean": "nacho-build clean",
        "build": "nacho-build",
        "build-clean": "nacho-build --clean"
    },
    "dependencies": {},
    "devDependencies": {
        "@matter/testing": "0.17.3",
        "@types/node": "^25.9.3",
        "@types/ws": "^8.18.1",
        "ws": "^8.21.0"
    },
    "engines": {
        "node": ">=22.13.0"
    }
}
