{
    "name": "@matter-server/thread-br",
    "version": "0.0.0-git",
    "type": "module",
    "description": "Thread Border Router communication: mDNS discovery, dataset codec, MeshCoP/CoAP/DTLS-EC-JPAKE diagnostic queries, OTBR REST adapter",
    "bugs": {
        "url": "https://github.com/matter-js/matterjs-server/issues"
    },
    "homepage": "https://github.com/matter-js/matterjs-server",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/matter-js/matterjs-server.git"
    },
    "author": "Open Home Foundation",
    "main": "dist/esm/index.js",
    "exports": {
        ".": {
            "dev-types": {
                "types": "./src/index.ts"
            },
            "import": {
                "types": "./dist/esm/index.d.ts",
                "default": "./dist/esm/index.js"
            }
        }
    },
    "scripts": {
        "clean": "nacho-build clean",
        "build": "nacho-build",
        "build-clean": "nacho-build --clean",
        "test": "matter-test --force-exit",
        "example": "node --experimental-strip-types --no-warnings"
    },
    "engines": {
        "node": ">=20.19.0 <22.0.0 || >=22.13.0"
    },
    "dependencies": {
        "@matter/main": "0.17.0",
        "@noble/curves": "^2.2.0",
        "@noble/hashes": "^2.2.0",
        "coap-packet": "^1.1.1"
    },
    "devDependencies": {
        "@matter/testing": "0.17.0",
        "@types/node": "^25.9.1"
    },
    "files": [
        "dist/**/*",
        "src/**/*",
        "LICENSE",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    }
}
