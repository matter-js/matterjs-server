// Type-check configuration for runnable example scripts. Examples are not built
// by nacho-build — they execute directly via `node --experimental-strip-types`.
// This file gives the IDE enough context to type-check them.
{
    "extends": "../../../tsc/tsconfig.base.json",
    "compilerOptions": {
        "noEmit": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "**/*.ts"
    ],
    "references": [
        {
            "path": "../src"
        }
    ]
}
